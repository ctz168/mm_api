# ═══════════════════════════════════════════════════════════════
#  config.env.example - 配置模板
#
#  使用方法：
#    cp config.env.example config.env
#    vim config.env   # 填入实际值
#
#  注意：
#    - config.env 已在 .gitignore 中，不会被提交
#    - 修改后无需改其他文件，所有脚本自动读取
#    - 通过环境变量覆盖时使用 TUNNEL_ 前缀
# ═══════════════════════════════════════════════════════════════

# ─── ngrok ──────────────────────────────────────────────
# 从 https://dashboard.ngrok.com/get-started/your-authtoken 获取
NGROK_AUTHTOKEN=3AZZSmSvlfaZj8kp8quBj2MzFAY_4mtMewL9DYrkb72iQQDQv

# ngrok 固定域名前缀（不含 .ngrok-free.dev）
# 免费版每次启动随机分配，付费版可固定
NGROK_DOMAIN=

# ─── 内网 API ──────────────────────────────────────────
# LLM API 地址
API_HOST=10.138.255.202
API_PORT=8080
API_KEY=Z.ai

# ─── 自动注入的认证 Headers ────────────────────────────
# 代理会自动添加这些 Headers，调用方无需关心
# 从 /etc/.z-ai-config 或平台获取
X_TOKEN=your_jwt_token_here
X_CHAT_ID=your_chat_id_here
X_USER_ID=your_user_id_here

# ─── 保活参数 ──────────────────────────────────────────
# 每次保活持续时长（秒），接近 cron 间隔（300s）
KEEPALIVE_DURATION=280
# 日志文件路径
LOG_FILE=/workspace/mm_api/seamless.log
# 工作目录
WORK_DIR=/workspace/mm_api
